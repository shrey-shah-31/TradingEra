# MongoDB Atlas or local
MONGO_URI=mongodb://127.0.0.1:27017/tradingera

# Strong secret in production
JWT_SECRET=change_me_to_a_long_random_string

# CORS origin for your Vite dev server or Vercel URL
FRONTEND_URL=http://localhost:5173

# Optional: Alpha Vantage for stocks (crypto uses Binance public API by default)
ALPHA_VANTAGE_KEY=

# Set to "true" to block NSE stock trades outside 09:15–15:30 IST (paper mode defaults to allowing)
NSE_STRICT_HOURS=false

# Server
PORT=5000

# [Optional] ExchangeRate-API key for multi-currency support.
# Get a free key at https://app.exchangerate-api.com/
# If not set, Yahoo Finance is used as fallback (no key needed).
EXCHANGERATE_API_KEY=
